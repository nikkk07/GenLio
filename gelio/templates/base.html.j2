<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
:root {
  --navy: {{ c.navy }};
  --navy-panel: {{ c.navy_panel }};
  --blue: {{ c.blue }};
  --gold: {{ c.gold }};
  --gold-light: {{ c.gold_light }};
  --text: {{ c.text }};
  --muted: {{ c.muted }};
  --hairline: rgba(232,179,61,.35);
}
{{ font_faces | safe }}
{% include "styles.css" %}
</style>
</head>
<body>
  <div class="slide role-{{ role }}" style="width:{{ w }}px;height:{{ h }}px;">
    <div class="glow"></div>

    <div class="photo-zone">
      {% if bg_data_uri %}<img class="bg" src="{{ bg_data_uri }}" alt="">{% endif %}
      <div class="photo-mask"></div>
      <div class="photo-mask-bottom"></div>
    </div>

    {% include "partials/decor.html.j2" %}

    <header class="topbar">
      {% include "partials/logo_block.html.j2" %}
      {% include "partials/step_badge.html.j2" %}
    </header>

    <main class="content">
      <div class="content-fit">
        {% block content %}{% endblock %}
      </div>
    </main>

    {% block tip %}
      {% if tip_html %}{% include "partials/tip_bar.html.j2" %}{% endif %}
    {% endblock %}

    <footer class="footer">
      {% block footer %}
        {% include "partials/swipe_pill.html.j2" %}
      {% endblock %}
    </footer>
  </div>
  <script>
    /* Auto-fit safety net: if the content column overflows its box (max-length
       copy, tall panels), shrink it via zoom instead of clipping. */
    (function () {
      var box = document.querySelector(".content");
      var fit = document.querySelector(".content-fit");
      if (!box || !fit) return;
      for (var i = 0; i < 5; i++) {
        if (box.scrollHeight <= box.clientHeight + 1) break;
        var z = parseFloat(fit.style.zoom || 1) * (box.clientHeight / box.scrollHeight);
        fit.style.zoom = Math.max(0.55, z);
      }
    })();
  </script>
</body>
</html>
