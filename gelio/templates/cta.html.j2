{% extends "base.html.j2" %}
{% block content %}
  <div class="closing-block">
    <span class="wings">{{ icon("wings") | safe }}</span>
    {% include "partials/stacked_headline.html.j2" %}
    {% if subhead_html %}
      <p class="subhead">{{ subhead_html | safe }}</p>
    {% elif body %}
      <p class="subhead">{{ body }}</p>
    {% endif %}
    <div class="cta-pill">{{ cta }}</div>
    <div class="contact">
      {% if contact.email %}<div class="row"><span class="ic">{{ icon("paper_plane") | safe }}</span>{{ contact.email }}</div>{% endif %}
      {% if contact.phone %}<div class="row"><span class="ic">{{ icon("users") | safe }}</span>{{ contact.phone }}</div>{% endif %}
      {% if contact.address %}<div class="row"><span class="ic">{{ icon("compass") | safe }}</span>{{ contact.address }}</div>{% endif %}
    </div>
  </div>
{% endblock %}
{% block tip %}{% endblock %}
