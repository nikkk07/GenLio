# gelio environment configuration
# Copy to `.env` and fill in your free-tier API keys.

# --- LLM provider selection ---
# Which provider to use as primary: "groq" or "gemini".
GELIO_PROVIDER=groq

# --- Groq (primary, free tier) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (fallback, free tier) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- AI image generation (Phase 3.5) ---
# Provider chain for slide backgrounds: Cloudflare (primary) -> Together
# (fallback) -> local branded gradient (always works, never needs a key).
#
# Cloudflare Workers AI — free tier ~10 imgs/day. Dashboard -> AI -> Workers AI;
# Account ID is in the URL / dashboard sidebar; create an API token with the
# "Workers AI" permission. https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Together AI (optional fallback) — free FLUX endpoint.
# https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free

# Legacy Pollinations token (Phase 2; no longer in the provider chain).
POLLINATIONS_TOKEN=

# --- Telegram approval gate (Phase 3) ---
# Create a bot with @BotFather to get the token; message @userinfobot (or your
# bot, then read getUpdates) to find your numeric chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Supabase dashboard sync (Phase 3, optional) ---
# Leave SUPABASE_URL blank to disable sync entirely (gelio runs fine without it).
# Use the project URL and the SERVICE ROLE key (server-side only — never ship to
# the browser). Create the table from supabase/schema.sql and a public bucket.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=slides
