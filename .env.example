# gelio environment configuration
# Copy to `.env` and fill in your free-tier API keys.

# --- LLM provider selection ---
# Which provider to use as primary: "groq" or "gemini".
GELIO_PROVIDER=groq

# --- Groq (primary, free tier) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (fallback, free tier) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- AI image generation (Phase 3.5) ---
# Provider chain for slide backgrounds: Cloudflare (primary) -> Together
# (fallback) -> local branded gradient (always works, never needs a key).
#
# Cloudflare Workers AI — free tier ~10 imgs/day. Dashboard -> AI -> Workers AI;
# Account ID is in the URL / dashboard sidebar; create an API token with the
# "Workers AI" permission. https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Together AI (optional fallback) — free FLUX endpoint.
# https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free

# Legacy Pollinations token (Phase 2; no longer in the provider chain).
POLLINATIONS_TOKEN=

# --- Telegram approval gate (Phase 3) ---
# Create a bot with @BotFather to get the token; message @userinfobot (or your
# bot, then read getUpdates) to find your numeric chat id.
# For multiple admins, separate with commas: 123456789,987654321
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Supabase dashboard sync (Phase 3, optional; REQUIRED for Instagram) ---
# Leave SUPABASE_URL blank to disable sync entirely (gelio runs fine without it).
# Use the bare project URL (https://<ref>.supabase.co — no /rest/v1 suffix) and
# the SERVICE ROLE key (server-side only — never ship to the browser). Create
# the table from supabase/schema.sql and a public bucket.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=slides

# --- X / Twitter publisher (Phase 4) ---
# developer.x.com -> create an app with Read+Write, OAuth 1.0a user context.
# All four keys required or the X publisher is disabled (post skips X).
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# X allows max 4 images per tweet; gelio posts the first N slides (hook + insights).
X_MAX_IMAGES=4

# --- Instagram publisher (Phase 4) ---
# Requires an IG Business/Creator account linked to a Facebook Page, a
# long-lived access token, AND Supabase sync enabled (the Graph API fetches
# slides from the public bucket URLs). Without these, IG is skipped gracefully.
IG_USER_ID=
IG_ACCESS_TOKEN=
