{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "GELIO_STATE": "supabase"
  },
  "build": {
    "env": {
      "GELIO_STATE": "supabase"
    }
  },
  "rewrites": [
    { "source": "/api/telegram", "destination": "/api/telegram" },
    { "source": "/api/telegram/(.*)", "destination": "/api/telegram" }
  ]
}
